# Application Environment
APP_NAME="Security Evaluation System"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_VERSION=2.0.0

# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_APP_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# Features
VITE_ENABLE_PWA=true
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=false

# Security
VITE_CSRF_TOKEN_ENABLED=true
VITE_SESSION_TIMEOUT=3600
VITE_MAX_LOGIN_ATTEMPTS=5

# Theme
VITE_DEFAULT_THEME=light
VITE_PRIMARY_COLOR=blue
VITE_BORDER_RADIUS=lg

# Pagination
VITE_PAGINATION_LIMIT=20
VITE_PAGINATION_OPTIONS="10,20,50,100"

# Upload
VITE_MAX_FILE_SIZE=5120
VITE_ALLOWED_FILE_TYPES="jpg,jpeg,png,pdf,doc,docx,xls,xlsx"

# Cache
VITE_CACHE_VERSION=v1
VITE_CACHE_DURATION=3600

# Monitoring
VITE_ENABLE_SENTRY=false
VITE_SENTRY_DSN=

# Map
VITE_GOOGLE_MAPS_API_KEY=
VITE_MAP_PROVIDER=openstreetmap