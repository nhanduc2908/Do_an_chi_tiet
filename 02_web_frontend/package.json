{
  "name": "security-evaluation-frontend",
  "version": "2.0.0",
  "description": "Security Evaluation System - Modern Frontend with Vite + Tailwind + Alpine.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "watch": "vite build --watch",
    "lint": "eslint resources/js --ext .js,.vue",
    "lint:fix": "eslint resources/js --ext .js,.vue --fix",
    "format": "prettier --write \"resources/**/*.{js,css,scss,vue}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@alpinejs/intersect": "^3.13.3",
    "@alpinejs/persist": "^3.13.3",
    "@alpinejs/trap": "^3.13.3",
    "alpinejs": "^3.13.3",
    "axios": "^1.6.2",
    "chart.js": "^4.4.0",
    "date-fns": "^3.0.6",
    "dompurify": "^3.0.8",
    "highlight.js": "^11.9.0",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "nprogress": "^0.2.0",
    "qs": "^6.11.2",
    "sortablejs": "^1.15.0",
    "swiper": "^11.0.5",
    "tippy.js": "^6.3.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/node": "^20.10.4",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vue/test-utils": "^2.4.3",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.19.2",
    "jsdom": "^23.0.1",
    "laravel-vite-plugin": "^0.8.0",
    "postcss": "^8.4.32",
    "postcss-import": "^15.1.0",
    "postcss-nesting": "^12.0.2",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.10",
    "sass": "^1.69.5",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8",
    "vite-plugin-full-reload": "^1.1.0",
    "vite-plugin-laravel": "^0.3.0",
    "vitest": "^1.0.4",
    "vue-eslint-parser": "^9.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}